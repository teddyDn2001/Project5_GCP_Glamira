# Repo-wide gitignore. Each project also has its own .gitignore for
# project-specific patterns (data exports, virtualenvs, etc.).

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Python (catch-all in case a project's local gitignore misses one) ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# --- Secrets — never, under any circumstance ---
**/.env
!**/.env.example

# --- Huge / binary inputs we never want on GitHub ---
**/*.bson
**/*.bson.gz
**/dump/
glamira_ubl*.tar.gz
IP-COUNTRY-REGION-CITY.BIN
