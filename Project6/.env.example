# Project 06 — runtime config (DO NOT COMMIT real .env)
# Inherits / overlaps with Project 05 envs.

# ---------- GCP project ----------
GCP_PROJECT_ID=unigap-de-glamira-data
GCP_REGION=asia-southeast1

# ---------- GCS (Data Lake) ----------
# Reuse Project 5 bucket; Project 6 uses a dedicated prefix tree under raw/p06/
GCS_BUCKET=unigap-prj5-raw
GCS_PREFIX_EVENTS=raw/p06/events
GCS_PREFIX_IP_LOCATIONS=raw/p06/ip_locations
GCS_PREFIX_PRODUCTS=raw/p06/products

# Logical "partition" date for this ingest run (YYYY-MM-DD)
INGEST_DATE=2026-05-10

# ---------- BigQuery (Data Warehouse) ----------
BQ_LOCATION=asia-southeast1
BQ_DATASET_RAW=glamira_raw
BQ_TABLE_EVENTS=events
BQ_TABLE_IP_LOCATIONS=ip_locations
BQ_TABLE_PRODUCTS=products

# Service account JSON key path (only if running OUTSIDE GCE; on the VM
# the attached SA `sa-p05-bq-loader@...` is auto-detected by ADC).
GOOGLE_APPLICATION_CREDENTIALS=

# ---------- MongoDB (source for raw events) ----------
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_ADMIN_USER=admin_user
MONGO_ADMIN_PWD=CHANGE_ME

RAW_DB=countly
RAW_COLL=summary

# ---------- Export tuning ----------
# How many docs per NDJSON.gz file (tune to keep individual files ~256 MB).
EVENTS_BATCH_SIZE=200000
# 0 = export all docs; >0 = cap (useful for smoke tests).
EVENTS_MAX_DOCS=0
# How many bytes to buffer before flushing to GCS (resumable uploads handle this internally).
EVENTS_UPLOAD_CHUNK_MB=8

# ---------- Cloud Function deploy ----------
CF_NAME=p06-gcs-to-bq-loader
CF_RUNTIME=python311
CF_ENTRY_POINT=trigger_bigquery_load
CF_SERVICE_ACCOUNT=sa-p05-bq-loader@unigap-de-glamira-data.iam.gserviceaccount.com
CF_TRIGGER_BUCKET=unigap-prj5-raw
# Eventarc filter so only Project 6 uploads trigger the function.
CF_TRIGGER_PREFIX_FILTER=raw/p06/
