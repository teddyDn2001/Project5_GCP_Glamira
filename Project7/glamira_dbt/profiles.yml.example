# Copy to ~/.dbt/profiles.yml (DO NOT commit real profiles.yml with secrets)
#
#   cp profiles.yml.example ~/.dbt/profiles.yml
#
# Auth: gcloud auth application-default login
#       (or service account JSON via method: service-account)

glamira:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: oauth
      project: unigap-de-glamira-data
      dataset: glamira
      location: asia-southeast1
      threads: 4
      timeout_seconds: 3600
