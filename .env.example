# Project 05 - local/VM runtime config (DO NOT COMMIT real .env)

# MongoDB (admin is used for admin tasks; app user can be used for pipelines)
MONGO_HOST=127.0.0.1
MONGO_PORT=27017

MONGO_ADMIN_USER=admin_user
MONGO_ADMIN_PWD=CHANGE_ME

MONGO_APP_USER=app_ingest
MONGO_APP_PWD=CHANGE_ME

# Databases / collections
RAW_DB=countly
RAW_COLL=summary

WORK_DB=glamira

# GCS (optional: only needed if exporting/uploading via scripts)
GCS_BUCKET=unigap-prj5-raw
INGEST_DATE=2026-04-22
RUN_DATE=2026-04-22

# IP2Location (use the BIN shipped with this repo)
IP2LOCATION_BIN=IP-COUNTRY-REGION-CITY.BIN

# Crawler tuning
MAX_ITEMS=0
SLEEP_MIN=1.0
SLEEP_MAX=2.5
REQUEST_TIMEOUT=20
MAX_RETRIES=6
BACKOFF_BASE=1.6
